---
interface Props {
  date: Date;
  readTime: number;
}

const { date, readTime } = Astro.props;
const formatted = date.toLocaleDateString("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<span class="meta">
  <time datetime={date.toISOString()}>{formatted}</time>
  <span aria-hidden="true"> &middot; </span>
  <span>{readTime} min read</span>
</span>
