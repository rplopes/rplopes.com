---
import { site } from "../../site.config";
import { OG_WIDTH, OG_HEIGHT } from "../lib/og";

interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: {
    publishedAt: string;
    updatedAt?: string;
  };
}

const { title, description, image, article } = Astro.props;
const { author } = site;
const twitterHandle = site.links.twitter ? `@${new URL(site.links.twitter).pathname.slice(1)}` : undefined;
const astroSite = Astro.site!;
const canonicalUrl = new URL(Astro.url.pathname, astroSite).href;
const rssUrl = new URL("/blog/rss.xml", astroSite).href;

const ogType = article ? "article" : "website";

const jsonLd = article
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: title,
      url: canonicalUrl,
      datePublished: article.publishedAt,
      ...(article.updatedAt && { dateModified: article.updatedAt }),
      ...(description && { description }),
      ...(image && { image: new URL(image, astroSite).href }),
      author: { "@type": "Person", name: author },
      publisher: { "@type": "Person", name: author },
    }
    : {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: author,
      url: astroSite.href,
      ...(description && { description }),
    };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    {description && <meta name="description" content={description} />}
    <meta name="author" content={author} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/images/favicon.png" />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    {description && <meta property="og:description" content={description} />}
    {image && <meta property="og:image" content={new URL(image, astroSite).href} />}
    {image && <meta property="og:image:width" content={String(OG_WIDTH)} />}
    {image && <meta property="og:image:height" content={String(OG_HEIGHT)} />}
    {article && <meta property="article:published_time" content={article.publishedAt} />}
    {article?.updatedAt && <meta property="article:modified_time" content={article.updatedAt} />}
    {article && <meta property="article:author" content={author} />}
    <meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
    {twitterHandle && <meta name="twitter:creator" content={twitterHandle} />}
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {image && <meta name="twitter:image" content={new URL(image, astroSite).href} />}
    <link rel="alternate" type="application/rss+xml" title={title} href={rssUrl} />
    <link rel="preload" href="/tokens.css" as="style" />
    <link rel="stylesheet" href="/document.css" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <nav class="site-nav" aria-label="Site">
      <a href="/" class="site-name">rplopes</a>
      <a href="/blog">blog</a>
      <a href="/blog/rss.xml">rss</a>
    </nav>
    <slot />
    <footer>
      <p>&copy; {new Date().getFullYear()} {site.title}</p>
    </footer>
  </body>
</html>
